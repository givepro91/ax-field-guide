---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="백엔드 출신 프로덕트 리드가 AX(AI Transformation)를 현장에서 정리하는 공개 작업 노트." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
