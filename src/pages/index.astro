---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { buildNav, type TrendItem } from '../nav';
import trends from '../../content/trends/index.json';

const entries = await getCollection('guide');
const groups = buildNav(entries);
const recent = ((trends.items || []) as TrendItem[]).slice(0, 3);

const cardDesc: Record<string, string> = {
  '개념': 'AX를 내 언어로 정의하고, 어떤 기준으로 실무에 적용하는지.',
  'Playbook': '승인 게이트·롤백·Human-in-the-loop 같은 반복 설계 패턴.',
  'Tools': 'Claude Code·Codex·MCP를 AX 관점에서 직접 써본 필드 리뷰.',
  'Experiments': '실험·관찰 기록 (준비 중).',
};
---

<Base title="AX Field Guide">
  <header class="topbar">
    <a class="brand" href="/">AX&nbsp;Field&nbsp;Guide<span class="dot">.</span></a>
    <nav class="topnav">
      {groups.map((g) => (g.firstHref ? <a href={g.firstHref}>{g.cat}</a> : <span class="muted">{g.cat}</span>))}
      <a href="/trends">동향</a>
    </nav>
  </header>

  <div class="wrap">
    <section class="hero">
      <p class="kick">공개 작업 노트 · 진행 중</p>
      <h1>AI를 <span class="q">도입</span>하는 일이 아니라, 판단 구조를 <span class="q">다시 설계</span>하는 일.</h1>
      <p class="sub">백엔드 출신 프로덕트 리드가 AX(AI Transformation)를 현장에서 배우며 정리하는 필드 가이드. 도구 자랑이 아니라, 문제를 어떻게 구조화하고 어디에 무엇을 붙였으며 무엇을 포기했는지를 남깁니다.</p>
      <div class="cta">
        <a class="pri" href="/guide/what-is-ax">AX란 무엇인가 읽기 →</a>
        <a class="sec" href="/trends">최근 동향 보기</a>
      </div>
    </section>

    <p class="sec-t">어디서부터 볼까</p>
    <div class="cards">
      {groups.map((g) => {
        const head = (
          <div class="c-h">
            <b>{g.cat}</b>
            <span class="en">{g.catEn || '—'}</span>
            <span class="cnt">{g.count > 0 ? g.count : '예정'}</span>
          </div>
        );
        return g.firstHref ? (
          <a class="card" href={g.firstHref}>{head}<p>{cardDesc[g.cat]}</p></a>
        ) : (
          <div class="card card-soon">{head}<p>{cardDesc[g.cat]}</p></div>
        );
      })}
      <a class="card" href="/trends">
        <div class="c-h"><b>동향</b><span class="en">Trends</span><span class="cnt">자동</span></div>
        <p>매일 자동 수집·요약하는 AX 기술 동향.</p>
      </a>
    </div>

    <p class="sec-t">최근 동향</p>
    <section class="trends">
      <div class="t-h"><span class="live"></span> 매일 자동 수집</div>
      <ul>
        {recent.map((it) => (
          <li>
            <div class="meta"><span class="src">{it.source}</span> · {it.date}</div>
            <a class="ti" href={it.url}>{it.title}</a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="site-footer">
      AX Field Guide — 판단 기준을 쌓아가는 작업 노트. · <a href="/guide/what-is-ax">읽기 시작 →</a>
    </footer>
  </div>
</Base>
