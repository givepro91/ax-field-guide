---
import { buildNav, type GuideEntry } from '../nav';
interface Props { entries?: GuideEntry[]; activeId?: string }
const { entries = [], activeId } = Astro.props;
const groups = buildNav(entries);
const activeHref = activeId ? `/guide/${activeId}` : '';
---

<nav class="sidenav" id="sidenav" aria-label="문서 색인">
  {groups.map((g) => {
    const isActiveGroup = g.articles.some((a) => a.href === activeHref);
    return (
    <details open={isActiveGroup}>
      <summary>
        <span class="chev"></span>
        <span class="grp-t">{g.cat}{g.catEn ? ` · ${g.catEn}` : ''}</span>
        <span class="cnt">{g.count}</span>
      </summary>
      <ul>
        {g.articles.map((a) => (
          <li class={a.href === activeHref ? 'active' : ''}>
            <a href={a.href}><span class="ti">{a.title}</span>{a.draft && <span class="badge draft">draft</span>}</a>
          </li>
        ))}
        {g.planned.map((p) => (
          <li class="soon"><a href="#"><span class="ti">{p}</span><span class="badge">예정</span></a></li>
        ))}
        {g.articles.length === 0 && g.planned.length === 0 && <li class="empty">아직 없음</li>}
      </ul>
    </details>
    );
  })}
  <p class="noresult" id="noresult" aria-live="polite">검색 결과 없음</p>
</nav>

<script>
  // 긴 색인에서 현재 글이 보이도록 자동 스크롤(닫힌 그룹 밖이면 무해).
  document.querySelector('.sidenav li.active')?.scrollIntoView({ block: 'nearest' });

  const box = document.getElementById('nav-search') as HTMLInputElement | null;
  if (box) {
    const groups = Array.from(document.querySelectorAll('#sidenav details')) as HTMLDetailsElement[];
    const noresult = document.getElementById('noresult');
    box.addEventListener('input', () => {
      const term = box.value.trim().toLowerCase();
      let hits = 0;
      groups.forEach((g) => {
        let any = false;
        g.querySelectorAll('li').forEach((li) => {
          if (li.classList.contains('empty')) { li.style.display = term ? 'none' : ''; return; }
          const match = !term || (li.textContent || '').toLowerCase().includes(term);
          li.style.display = match ? '' : 'none';
          if (match) { any = true; hits++; }
        });
        g.style.display = any ? '' : 'none';
        if (term && any) g.open = true;
      });
      if (noresult) noresult.style.display = term && hits === 0 ? 'block' : 'none';
    });
  }
</script>
