---
interface Props { crumbCategory?: string; crumbTitle?: string; present?: boolean }
const { crumbCategory, crumbTitle, present = false } = Astro.props;
---

<header class="topbar">
  {present && (
    <button class="nav-toggle" id="nav-toggle" aria-label="색인 접기/펴기 (단축키 [)" title="색인 접기/펴기 ([)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="16" rx="2" /><line x1="9" y1="4" x2="9" y2="20" />
      </svg>
    </button>
  )}
  <a class="brand" href="/">AX&nbsp;Field&nbsp;Guide<span class="dot">.</span></a>
  {crumbTitle && (
    <span class="crumb">
      {crumbCategory && <>{crumbCategory} / </>}<b>{crumbTitle}</b>
    </span>
  )}
  <label class="search">
    <span class="mono">⌕</span>
    <input id="nav-search" type="search" placeholder="문서 검색…" aria-label="문서 검색" />
  </label>
  <a class="gnb-link" href="/trends"><span class="live" aria-hidden="true"></span>동향</a>
  {present && (
    <button class="btn-present" id="present-btn" aria-haspopup="dialog">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="13" rx="2" /><path d="M12 17v3M8 20h8" />
      </svg>
      프레젠테이션
    </button>
  )}
</header>

<script>
  // 사이드바 접기 토글 — [ 단축키(e.code 라 한/영 무관) + localStorage 로 상태 유지.
  const toggle = document.getElementById('nav-toggle');
  const shell = document.querySelector('.shell');
  if (toggle && shell) {
    const KEY = 'axfg-nav-collapsed';
    const apply = (c: boolean) => { shell.classList.toggle('nav-collapsed', c); toggle.setAttribute('aria-pressed', String(c)); };
    apply(localStorage.getItem(KEY) === '1');
    toggle.addEventListener('click', () => {
      const c = !shell.classList.contains('nav-collapsed');
      apply(c); localStorage.setItem(KEY, c ? '1' : '0');
    });
    document.addEventListener('keydown', (e) => {
      const el = e.target as HTMLElement | null;
      const typing = !!el && (/^(INPUT|TEXTAREA|SELECT)$/.test(el.tagName) || el.isContentEditable);
      if (e.code === 'BracketLeft' && !typing && !e.metaKey && !e.ctrlKey && !e.altKey) { e.preventDefault(); toggle.click(); }
    });
  }
</script>
