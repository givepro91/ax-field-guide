---
interface Col { head: string; sub?: string; points?: string[]; accent?: boolean }
interface Step { label: string; note?: string }
interface Slide {
  layout?: 'cover' | 'thesis' | 'compare' | 'flow' | 'stack' | 'bullets';
  kick?: string;
  title: string;
  body?: string;
  bullets?: string[];
  cover?: boolean;
  columns?: Col[];
  steps?: Step[];
  layers?: Step[];
  note?: string;
}
interface Props { slides?: Slide[] }
const { slides = [] } = Astro.props;

// layout 미지정이면 담긴 데이터로 추론한다 — 작성자는 데이터만 주면 된다.
function layoutOf(s: Slide): string {
  if (s.layout) return s.layout;
  if (s.cover) return 'cover';
  if (s.columns && s.columns.length) return 'compare';
  if (s.steps && s.steps.length) return 'flow';
  if (s.layers && s.layers.length) return 'stack';
  return 'bullets';
}
const total = slides.length;
---

{total > 0 && (
  <div class="deck" id="deck" role="dialog" aria-modal="true" aria-label="프레젠테이션" tabindex="-1">
    <div class="deck-bar"><i id="deck-prog"></i></div>
    <div class="deck-stage" id="deck-stage">
      {slides.map((s, idx) => {
        const lay = layoutOf(s);
        return (
          <section class={`slide lay-${lay}`}>
            <span class="s-idx" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
            <span class="s-no">{String(idx + 1).padStart(2, '0')} / {String(total).padStart(2, '0')}</span>
            {s.kick && <p class="s-kick">{s.kick}</p>}
            <h2>{s.title}</h2>

            {lay === 'thesis' && s.body && <p class="s-thesis">{s.body}</p>}

            {lay !== 'thesis' && s.body && <p class="s-body">{s.body}</p>}

            {lay === 'compare' && s.columns && (
              <div class="s-cols" data-n={s.columns.length}>
                {s.columns.map((c) => (
                  <div class={`s-col${c.accent ? ' is-accent' : ''}`}>
                    <div class="s-col-h">{c.head}</div>
                    {c.sub && <div class="s-col-sub">{c.sub}</div>}
                    {c.points && c.points.length > 0 && (
                      <ul>{c.points.map((p) => (<li>{p}</li>))}</ul>
                    )}
                  </div>
                ))}
              </div>
            )}

            {lay === 'flow' && s.steps && (
              <ol class="s-flow">
                {s.steps.map((st, i) => (
                  <li>
                    <span class="s-n">{i + 1}</span>
                    <span class="s-flow-b"><b>{st.label}</b>{st.note && <i>{st.note}</i>}</span>
                  </li>
                ))}
              </ol>
            )}

            {lay === 'stack' && s.layers && (
              <div class="s-stack">
                {s.layers.map((ly) => (
                  <div class="s-layer"><b>{ly.label}</b>{ly.note && <span>{ly.note}</span>}</div>
                ))}
              </div>
            )}

            {(lay === 'bullets' || (lay !== 'compare' && lay !== 'flow' && lay !== 'stack')) && s.bullets && s.bullets.length > 0 && (
              <ul class="s-bullets">{s.bullets.map((b) => (<li><span class="n">·</span> {b}</li>))}</ul>
            )}

            {s.note && <p class="s-note">{s.note}</p>}
          </section>
        );
      })}
    </div>
    <div class="deck-foot">
      <button class="exit" id="exit-btn">✕ 닫기 (Esc)</button>
      <button id="prev-btn">← 이전</button>
      <span class="count" id="deck-count">1 / {total}</span>
      <button id="next-btn">다음 →</button>
      <span class="hint">← → 이동 · F 전체화면 · Esc 종료</span>
    </div>
  </div>
)}

<script>
  const deck = document.getElementById('deck');
  if (deck) {
    const stage = document.getElementById('deck-stage');
    const slides = Array.from(deck.querySelectorAll('.slide'));
    const count = document.getElementById('deck-count');
    const prog = document.getElementById('deck-prog') as HTMLElement | null;
    let i = 0;
    const show = (n: number) => {
      i = Math.max(0, Math.min(slides.length - 1, n));
      slides.forEach((s, k) => s.classList.toggle('on', k === i));
      document.dispatchEvent(new CustomEvent('deck:slide', { detail: i })); // 슬라이드 넘기면 주석 클리어
      if (count) count.textContent = `${i + 1} / ${slides.length}`;
      if (prog) prog.style.width = `${((i + 1) / slides.length) * 100}%`;
    };
    const bg = () => Array.from(document.querySelectorAll('.topbar, .shell')) as HTMLElement[];
    const open = () => {
      deck.classList.add('open'); document.body.classList.add('presenting');
      bg().forEach((el) => (el.inert = true)); // 배경 비활성(aria-modal 일관)
      show(0); deck.focus();
    };
    const close = () => {
      deck.classList.remove('open'); document.body.classList.remove('presenting');
      bg().forEach((el) => (el.inert = false));
      if (document.fullscreenElement) document.exitFullscreen?.();
      (document.getElementById('present-btn') as HTMLElement | null)?.focus(); // 트리거로 포커스 복귀
    };
    const fs = () => { if (!document.fullscreenElement) deck.requestFullscreen?.(); else document.exitFullscreen?.(); };
    document.getElementById('present-btn')?.addEventListener('click', open);
    document.getElementById('exit-btn')?.addEventListener('click', close);
    document.getElementById('next-btn')?.addEventListener('click', (e) => { e.stopPropagation(); show(i + 1); });
    document.getElementById('prev-btn')?.addEventListener('click', (e) => { e.stopPropagation(); show(i - 1); });
    stage?.addEventListener('click', () => { if (i >= slides.length - 1) close(); else show(i + 1); });
    document.addEventListener('keydown', (e) => {
      if (!deck.classList.contains('open')) return;
      if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown') { e.preventDefault(); show(i + 1); }
      else if (e.key === 'ArrowLeft' || e.key === 'PageUp') { e.preventDefault(); show(i - 1); }
      else if (e.key === 'Escape') close();
      else if (e.key === 'f' || e.key === 'F') fs();
    });
  }
</script>
